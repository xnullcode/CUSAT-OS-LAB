#include <stdio.h>

int main() {
    int capacity, n;
    int pages[100], frames[100], lastUsed[100];

    printf("Frames: ");   scanf("%d", &capacity);
    printf("Pages: ");    scanf("%d", &n);
    printf("Enter pages: ");
    for (int i = 0; i < n; i++) scanf("%d", &pages[i]);

    // initialize all frames as empty
    for (int i = 0; i < capacity; i++) {
        frames[i] = -1;
        lastUsed[i] = 0;
    }

    int faults = 0;
    for (int i = 0; i < n; i++) {
        int found = 0;

        // check if page already in a frame (page hit)
        for (int j = 0; j < capacity; j++) {
            if (frames[j] == pages[i]) {
                found = 1;
                lastUsed[j] = i;  // update last used time
                break;
            }
        }

        // page not found — need to replace (page fault)
        if (!found) {
            // find least recently used frame
            int lru = 0;
            int done=0;
            for(int j=0;j<capacity;j++){
                if(frames[j]==-1){
                    lru=j;
                    done++;
                    break;
                }
            }
            for (int j = 1; j < capacity; j++)
                if (lastUsed[j] < lastUsed[lru])
                    lru = j;

            frames[lru] = pages[i];  // replace with new page
            lastUsed[lru] = i;       // mark when it was loaded
            faults++;
        }
    }

    printf("Page faults: %d\n", faults);
    return 0;
}
